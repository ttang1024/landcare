{
  "name": "nzlandcare/landcarelink-api",
  "description": "LandcareLink Catchment Mapping Platform — PHP 8.3 backend",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.3",
    "ext-pdo": "*",
    "ext-json": "*",
    "php-di/php-di": "^7.0",
    "ramsey/uuid": "^4.7",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": { "Landcare\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Landcare\\Tests\\": "tests/" }
  },
  "scripts": {
    "serve": "php -S localhost:8080 -t public",
    "test": "phpunit",
    "stan": "phpstan analyse src --level=6",
    "cs": "phpcs --standard=PSR12 src"
  },
  "config": { "sort-packages": true }
}
